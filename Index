</div>

<script src="https://elfsightcdn.com/platform.js" async></script>

<script>
(function() {
  const bubble = document.getElementById('musicBubble');
  const panel = document.getElementById('playerPanel');
  let isPanelVisible = false;
  let audioElement = null;
  
  function findAudioElement() {
    const audio = document.querySelector('audio');
    if (audio && audio !== audioElement) {
      audioElement = audio;
      audio.addEventListener('play', () => bubble.classList.add('playing'));
      audio.addEventListener('pause', () => bubble.classList.remove('playing'));
      audio.addEventListener('ended', () => bubble.classList.remove('playing'));
      if (!audio.paused && !audio.ended) bubble.classList.add('playing');
    }
  }
  
  const observer = new MutationObserver(() => findAudioElement());
  observer.observe(document.body, { childList: true, subtree: true });
  
  bubble.addEventListener('click', (e) => {
    e.stopPropagation();
    if (isPanelVisible) {
      panel.classList.add('hidden');
      isPanelVisible = false;
    } else {
      panel.classList.remove('hidden');
      isPanelVisible = true;
      setTimeout(findAudioElement, 500);
    }
  });
  
  document.addEventListener('click', (event) => {
    if (isPanelVisible && !panel.contains(event.target) && !bubble.contains(event.target)) {
      panel.classList.add('hidden');
      isPanelVisible = false;
    }
  });
  
  setInterval(findAudioElement, 3000);
  setTimeout(findAudioElement, 1500);
  
  // Botón de oficinas - activa el reproductor
  const oficinasBtn = document.getElementById('oficinasBtn');
  if (oficinasBtn) {
    oficinasBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      if (!isPanelVisible) {
        panel.classList.remove('hidden');
        isPanelVisible = true;
        setTimeout(findAudioElement, 300);
      }
    });
  }
})();
</script>


    <style>

#musicOverlay {
    display: none;
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(0,0,0,0.2);
    z-index: 99998;
    backdrop-filter: blur(2px);
}
#musicOverlay.show { display: block; }

#musicWidgetContainer {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 99999;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

/* === ESTADO COLAPSADO (Burbuja marca de agua) === */
#musicWidgetContainer.collapsed {
    width: 50px;
    height: 50px;
}

#musicBubble {
    position: absolute;
    top: 0; left: 0;
    width: 50px; height: 50px;
    background: rgba(159, 34, 65, 0.08);
    color: rgba(159, 34, 65, 0.25);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    cursor: pointer;
    border: 1px solid rgba(159, 34, 65, 0.06);
    backdrop-filter: blur(1px);
    box-shadow: none;
    z-index: 2;
    transition: all 0.3s ease;
}

#musicBubble:hover {
    background: rgba(159, 34, 65, 0.2);
    color: rgba(159, 34, 65, 0.5);
    border: 1px solid rgba(159, 34, 65, 0.15);
    transform: scale(1.15);
}

#musicBubble i {
    animation: musicPulse 3s ease-in-out infinite;
}

@keyframes musicPulse {
    0%, 100% { transform: scale(1); opacity: 0.3; }
    50% { transform: scale(1.1); opacity: 0.6; }
}

/* Estado "reproduciendo" - un poco más visible */
#musicBubble.has-audio {
    background: rgba(159, 34, 65, 0.15);
    color: rgba(159, 34, 65, 0.4);
}

/* === ESTADO EXPANDIDO (Barra inferior) === */
#musicWidgetContainer.expanded {
    width: calc(100% - 40px);
    max-width: 800px;
    height: 110px;
    bottom: 20px;
    right: 20px;
    left: auto;
}

#musicBar {
    width: 100%;
    height: 100%;
    background: linear-gradient(145deg, #1a1a2e 0%, #16213e 100%);
    border-radius: 16px;
    box-shadow: 0 5px 25px rgba(0,0,0,0.4);
    border: 1px solid rgba(255,255,255,0.08);
    display: flex;
    align-items: center;
    padding: 8px 45px 8px 15px;
    box-sizing: border-box;
    position: relative;
    opacity: 0;
    transform: scale(0.8);
    transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    overflow: hidden;
}

#musicWidgetContainer.expanded #musicBar {
    opacity: 1;
    transform: scale(1);
}

#musicWidgetWrapper {
    width: 100%;
    height: 90px;
    opacity: 0;
    transition: opacity 0.3s ease 0.15s;
    overflow: hidden;
}

#musicWidgetContainer.expanded #musicWidgetWrapper {
    opacity: 1;
}

#musicCloseBtn {
    position: absolute;
    top: 8px;
    right: 12px;
    background: rgba(255,255,255,0.1);
    border: none;
    color: rgba(255,255,255,0.7);
    width: 28px;
    height: 28px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: all 0.2s;
    line-height: 1;
}
#musicCloseBtn:hover {
    background: rgba(233,69,96,0.3);
    color: #fff;
}

#musicWidgetContainer.collapsed #musicBar {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.8);
}

@media (max-width: 768px) {
    #musicWidgetContainer.expanded {
        width: calc(100% - 20px);
        right: 10px;
        left: 10px;
        height: 130px;
    }
    #musicWidgetWrapper {
        height: 110px;
    }
    #musicWidgetContainer.collapsed {
        width: 44px;
        height: 44px;
    }
    #musicBubble {
        width: 44px;
        height: 44px;
        font-size: 16px;
    }
}


                        else { $("#faq-contenido").html(generarMensajeVacio('fa-folder-open','Sin información disponible','No se encontraron preguntas frecuentes en este momento. Intenta más tarde.')); }
                    },
                    error: function() { $("#faq-contenido").html(generarMensajeVacio('fa-exclamation-triangle','Error al cargar','No se pudo conectar con el servidor. Verifica tu conexión e intenta nuevamente.')); }
                });
            }
            function renderizarVistaActores() {
                if (!faqDataGlobal || !faqDataGlobal.actores || faqDataGlobal.actores.length === 0) {
                    $("#faq-contenido").html(generarMensajeVacio('fa-users-slash','Sin información disponible','No hay preguntas frecuentes configuradas en este momento. Intenta más tarde.'));
                    return;
                }
                let html = '';
                if (faqDataGlobal.contenido_intro) {
                    let intros = faqDataGlobal.contenido_intro.filter(i => i.tipo_nivel === 'principal');
                    if (intros.length > 0) {
                        html += '<div class="faq-intro">';
                        intros.forEach(i => html += `<div class="intro-item"><h5 class="intro-titulo">${i.titulo}</h5><div class="intro-contenido">${i.contenido}</div></div>`);
                        html += '</div>';
                    }
                }
                html += '<div class="faq-section-title"><h5>¿Quién eres?</h5><p>Selecciona tu perfil</p></div>';
                html += '<div class="faq-actores-grid">';
                faqDataGlobal.actores.forEach(a => {
                    html += `<div class="faq-actor-card" onclick="renderizarCategorias(${a.id_actor})" style="background:${a.color_fondo || '#9f2241'}"><i class="fas ${a.icono || 'fa-user'}"></i><h4>${a.nombre || 'Sin nombre'}</h4><p>${a.descripcion || ''}</p></div>`;
                });
                html += '</div>';
                $("#faq-contenido").html(html);
            }
            function renderizarCategorias(idActor) {
                let actor = faqDataGlobal.actores.find(a => a.id_actor == idActor);
                if (!actor) { $("#faq-contenido").html(`<div class="faq-breadcrumb"><a href="#" onclick="renderizarVistaActores(); return false;"><i class="fas fa-arrow-left"></i> Volver al inicio</a></div>`+generarMensajeVacio('fa-user-slash','Perfil no encontrado','El perfil seleccionado no está disponible.')); return; }
                let html = `<div class="faq-breadcrumb"><a href="#" onclick="renderizarVistaActores(); return false;"><i class="fas fa-arrow-left"></i> Volver al inicio</a></div>`;
                html += `<div class="faq-actor-header"><h4><i class="fas ${actor.icono || 'fa-user'}" style="color:${actor.color_fondo || '#9f2241'}"></i> ${actor.nombre}</h4>${actor.descripcion ? `<p>${actor.descripcion}</p>` : ''}</div>`;
                if (!actor.categorias || actor.categorias.length === 0) { html += generarMensajeVacio('fa-folder-open','Sin categorías disponibles','Este perfil aún no tiene categorías configuradas.'); $("#faq-contenido").html(html); return; }
                html += '<div class="faq-section-title"><h5>Categorías</h5><p>Selecciona un tema</p></div><div class="faq-categorias-grid">';
                actor.categorias.forEach(cat => {
                    html += `<div class="faq-categoria-card" onclick="renderizarPreguntas(${idActor}, ${cat.id_categoria})"><i class="fas ${cat.icono || 'fa-folder'}"></i><div class="faq-cat-info"><h5>${cat.nombre || 'Sin nombre'} <i class="fas fa-chevron-right faq-arrow"></i></h5><p>${cat.descripcion || ''}</p></div></div>`;
                });
                html += '</div>';
                $("#faq-contenido").html(html);
            }
            function renderizarPreguntas(idActor, idCat) {
                let actor = faqDataGlobal.actores.find(a => a.id_actor == idActor);
                let cat = actor.categorias.find(c => c.id_categoria == idCat);
                if (!cat) { $("#faq-contenido").html(`<div class="faq-breadcrumb"><a href="#" onclick="renderizarCategorias(${idActor}); return false;"><i class="fas fa-arrow-left"></i> Volver a categorías</a></div>`+generarMensajeVacio('fa-folder-open','Categoría no encontrada','La categoría seleccionada no está disponible.')); return; }
                let html = `<div class="faq-breadcrumb"><a href="#" onclick="renderizarCategorias(${idActor}); return false;"><i class="fas fa-arrow-left"></i> Volver a categorías</a></div>`;
                html += `<div class="faq-actor-header"><h4><i class="fas ${cat.icono || 'fa-folder'}" style="color:${actor.color_fondo || '#9f2241'}"></i> ${cat.nombre}</h4>${cat.descripcion ? `<p>${cat.descripcion}</p>` : ''}</div>`;
                let totalPreguntas = 0;
                if (cat.preguntas) totalPreguntas += cat.preguntas.length;
                if (cat.subcategorias) { cat.subcategorias.forEach(s => { if (s.preguntas) totalPreguntas += s.preguntas.length; }); }
                if (totalPreguntas === 0) { html += generarMensajeVacio('fa-question-circle','Sin preguntas disponibles','Esta categoría aún no tiene preguntas frecuentes configuradas.'); $("#faq-contenido").html(html); return; }
                if (cat.subcategorias && cat.subcategorias.length > 0) {
                    html += '<div class="faq-subcategorias-container">';
                    html += '<button class="faq-subcategoria-btn active" onclick="filtrarSubcat(0, this)">Todas</button>';
                    cat.subcategorias.forEach(s => { html += `<button class="faq-subcategoria-btn" onclick="filtrarSubcat(${s.id_subcategoria}, this)">${s.nombre}</button>`; });
                    html += '</div>';
                }
                html += '<div class="faq-preguntas-container">';
                if (cat.preguntas && cat.preguntas.length > 0) { cat.preguntas.forEach(p => html += generarHTMLPregunta(p, 0)); }
                if (cat.subcategorias) { cat.subcategorias.forEach(s => { if (s.preguntas && s.preguntas.length > 0) { s.preguntas.forEach(p => html += generarHTMLPregunta(p, s.id_subcategoria)); } }); }
                html += '</div>';
                $("#faq-contenido").html(html);
                bindEventosPreguntas();
            }
            function generarHTMLPregunta(p, subId, ruta = '') {
                let tagsHtml = '';
                if (p.etiquetas) { tagsHtml = '<div class="faq-tags">' + p.etiquetas.split(',').map(t => `<span class="faq-tag">${t.trim()}</span>`).join('') + '</div>'; }
                return `<div class="faq-item ${p.destacada ? 'destacada' : ''}" data-subcategoria="${subId}" data-grupo="${ruta}"><div class="faq-question"><h5>${p.destacada ? '* ' : ''}${p.pregunta}</h5><div class="faq-toggle"><i class="fas fa-chevron-down"></i></div></div><div class="faq-answer">${ruta ? `<div class="faq-ruta"><small><i class="fas fa-folder-open"></i> ${ruta}</small></div>` : ''}<p>${p.respuesta}</p>${tagsHtml}</div></div>`;
            }
            function buscarPreguntas(termino) {
                if (!faqDataGlobal || termino.length < 3) return;
                let palabras = termino.toLowerCase().split(' ').filter(p => p.length > 0);
                let resultados = [];
                faqDataGlobal.actores.forEach(a => {
                    if (!a.categorias) return;
                    a.categorias.forEach(c => {
                        if (c.preguntas) { c.preguntas.forEach(p => { if (cumpleAND(p, palabras)) { p.ruta = `${a.nombre} > ${c.nombre}`; resultados.push(p); } }); }
                        if (c.subcategorias) { c.subcategorias.forEach(s => { if (s.preguntas) { s.preguntas.forEach(p => { if (cumpleAND(p, palabras)) { p.ruta = `${a.nombre} > ${c.nombre} > ${s.nombre}`; resultados.push(p); } }); } }); }
                    });
                });
                renderizarResultadosBusqueda(resultados, termino);
            }
            function cumpleAND(p, pal) {
                let t = ((p.pregunta || '') + " " + (p.respuesta || '') + " " + (p.etiquetas || "")).toLowerCase();
                return pal.every(word => t.includes(word));
            }
            function renderizarResultadosBusqueda(res, term) {
                let html = `<div class="faq-breadcrumb"><a href="#" onclick="renderizarVistaActores(); return false;"><i class="fas fa-arrow-left"></i> Volver al inicio</a></div>`;
                if (res.length === 0) { html += generarMensajeVacio('fa-search','Sin resultados',`No se encontraron preguntas para "${term}". Intenta con otros términos.`); $("#faq-contenido").html(html); return; }
                let grupos = {};
                res.forEach(p => { if (p.ruta) grupos[p.ruta] = (grupos[p.ruta] || 0) + 1; });
                html += `<div class="faq-search-header p-3 bg-white border-bottom shadow-sm sticky-top"><div class="d-flex justify-content-between align-items-center mb-2"><div class="small">Se encontraron <strong>${res.length}</strong> resultado(s)</div><div class="faq-controles-nav"><button class="btn_mini btn_ginda" onclick="navegarCoincidencia(-1)"><i class="fas fa-chevron-up"></i></button><span id="contador-nav" class="mx-2 font-weight-bold">0 / 0</span><button class="btn_mini btn_ginda" onclick="navegarCoincidencia(1)"><i class="fas fa-chevron-down"></i></button></div></div><div id="faq-pills-container" class="d-flex flex-wrap gap-2 mt-2"></div></div>`;
                html += '<div class="faq-preguntas-container">';
                res.forEach(p => {
                    let regex = new RegExp(`(${term.split(' ').join('|')})`, 'gi');
                    let pMark = {...p, pregunta: p.pregunta.replace(regex, '<mark class="faq-resaltado">$1</mark>'), respuesta: p.respuesta.replace(regex, '<mark class="faq-resaltado">$1</mark>')};
                    html += generarHTMLPregunta(pMark, 0, p.ruta);
                });
                html += "</div>";
                $("#faq-contenido").html(html);
                generarPills(grupos, term);
                bindEventosPreguntas();
                setTimeout(() => { todasLasCoincidencias = document.querySelectorAll('mark.faq-resaltado'); coincidenciasEncontradas = [...todasLasCoincidencias]; indiceCoincidencia = -1; if (coincidenciasEncontradas.length > 0) navegarCoincidencia(1); }, 100);
            }
            function navegarCoincidencia(dir) {
                if (coincidenciasEncontradas.length === 0) return;
                if (indiceCoincidencia >= 0 && indiceCoincidencia < coincidenciasEncontradas.length) { coincidenciasEncontradas[indiceCoincidencia].classList.remove('current-match'); }
                indiceCoincidencia += dir;
                if (indiceCoincidencia >= coincidenciasEncontradas.length) indiceCoincidencia = 0;
                if (indiceCoincidencia < 0) indiceCoincidencia = coincidenciasEncontradas.length - 1;
                const actual = coincidenciasEncontradas[indiceCoincidencia];
                actual.classList.add('current-match');
                $(".faq-item").hide().removeClass("active");
                $(actual).closest(".faq-item").show().addClass("active");
                actual.scrollIntoView({ behavior: 'smooth', block: 'center' });
                $("#contador-nav").text(`${indiceCoincidencia + 1} / ${coincidenciasEncontradas.length}`);
            }
            function filtrarSubcat(id, btn) {
                $(".faq-subcategoria-btn").removeClass("active");
                $(btn).addClass("active");
                if (id == 0) { $(".faq-item").show(); } else { $(".faq-item").hide(); $(`.faq-item[data-subcategoria="${id}"]`).show(); }
            }
            function bindEventosPreguntas() { $(".faq-question").off("click").on("click", function() { $(this).closest(".faq-item").toggleClass("active"); }); }
            function generarPills(grupos, term) {
                let $cont = $("#faq-pills-container"); $cont.empty();
                if (Object.keys(grupos).length > 1) {
                    $cont.append(`<button class="faq-pill active" onclick="filtrarPorPill(this, 'all', '${term}')">Todas</button>`);
                    Object.keys(grupos).forEach(ruta => { let label = ruta.split('>').pop().trim(); $cont.append(`<button class="faq-pill" onclick="filtrarPorPill(this, '${ruta}', '${term}')">${label}</button>`); });
                }
            }
            function filtrarPorPill(btn, ruta, term) {
                $(".faq-pill").removeClass("active"); $(btn).addClass("active"); indiceCoincidencia = -1;
                coincidenciasEncontradas = (ruta === 'all') ? [...todasLasCoincidencias] : [...todasLasCoincidencias].filter(m => $(m).closest(".faq-item").attr("data-grupo") === ruta);
                if (coincidenciasEncontradas.length > 0) navegarCoincidencia(1); else $("#contador-nav").text("0 / 0");
            }
            $(document).ready(function() {
                $('#modal-faq').appendTo('body');
                var modalFaq = document.getElementById('modal-faq');
                if (modalFaq) { modalFaq.addEventListener('show.bs.modal', function () { cargarEstructuraFaq(); }); }
                $("#btn-faq-buscar").on("click", function(e) { e.preventDefault(); let termino = $("#faq-buscar").val().trim(); if (termino.length >= 3) buscarPreguntas(termino); });
            });
        </script>
